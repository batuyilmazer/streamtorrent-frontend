---
import CollectionDetailScreen from '@/features/collections/screens/CollectionDetailScreen';
import AppProviders from '@/components/providers/AppProviders';
import BaseLayout from '@/layouts/BaseLayout.astro';

const { id } = Astro.params;
if (!id) return Astro.redirect('/collections');
---

<BaseLayout title="StreamTorrent — Koleksiyon">
  <AppProviders client:load>
    <CollectionDetailScreen collectionId={id} />
  </AppProviders>
</BaseLayout>
