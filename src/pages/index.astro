---
import '@/styles/global.css';
import TorrentApp from '@/components/TorrentApp';
---

<!DOCTYPE html>
<html lang="tr" class="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>StreamTorrent</title>
    <meta name="description" content=".torrent yükleyin veya magnet linki yapıştırın, videoyu anında izleyin." />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <header class="border-b border-border px-6 py-4">
      <div class="mx-auto max-w-5xl flex items-center gap-3">
        <svg
          class="size-5 text-primary"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path d="M4.5 4.5a3 3 0 00-3 3v9a3 3 0 003 3h8.25a3 3 0 003-3v-9a3 3 0 00-3-3H4.5zM19.94 18.75l-2.69-2.69V7.94l2.69-2.69c.944-.945 2.56-.276 2.56 1.06v11.38c0 1.336-1.616 2.005-2.56 1.06z" />
        </svg>
        <span class="font-semibold tracking-tight">StreamTorrent</span>
        <span class="text-xs text-muted-foreground uppercase tracking-widest">beta</span>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-8">
      <TorrentApp client:load />
    </main>
  </body>
</html>
